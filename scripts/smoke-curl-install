#!/usr/bin/env sh
set -eu

version="${1:-latest}"
install_dir="$(mktemp -d)"
script_dir="$(CDPATH= cd "$(dirname "$0")" && pwd)"
installer="${HZ_INSTALLER:-$script_dir/install.sh}"
# Set HZ_INSTALLER_URL to smoke a published installer instead of this checkout.

cleanup() {
  rm -rf "$install_dir"
}
trap cleanup EXIT INT TERM

if [ -n "${HZ_INSTALLER_URL:-}" ]; then
  installer="$install_dir/install.sh"
  curl -fsSL "$HZ_INSTALLER_URL" -o "$installer"
fi

HZ_INSTALL_DIR="$install_dir" HZ_VERSION="$version" sh "$installer"
test -x "$install_dir/hz"
"$install_dir/hz" --version
