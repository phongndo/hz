#!/usr/bin/env sh
set -eu

version="${1:-latest}"
tmp_dir="$(mktemp -d)"

if ! command -v mise >/dev/null 2>&1; then
  echo "smoke-mise: missing required command: mise" >&2
  exit 1
fi

cleanup() {
  rm -rf "$tmp_dir"
}
trap cleanup EXIT INT TERM

mkdir -p "$tmp_dir/config"
cat >"$tmp_dir/config/config.toml" <<'EOF'
[tool_alias]
hz = "github:phongndo/hz"
EOF

MISE_DATA_DIR="$tmp_dir/data" \
  MISE_CONFIG_DIR="$tmp_dir/config" \
  MISE_CACHE_DIR="$tmp_dir/cache" \
  mise x "hz@$version" -- hz --version
